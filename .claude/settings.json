{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path // empty'); [ -n \"$FILE\" ] && npx --no-install prettier --write --ignore-unknown \"$FILE\" >/dev/null 2>&1 || true"
          }
        ]
      }
    ]
  }
}
